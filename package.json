{
    "name": "gspec",
    "version": "2.0.1",
    "description": "Install gspec specification commands for Claude Code, Cursor, and other AI tools",
    "main": "bin/gspec.js",
    "type": "module",
    "bin": {
        "gspec": "bin/gspec.js"
    },
    "files": [
        "bin/",
        "lib/",
        "dist/",
        "plugin/",
        "templates/",
        "README.md"
    ],
    "scripts": {
        "pretest": "node scripts/build.js",
        "test": "node --test plugin/hooks/*/*.test.mjs test/*.test.mjs",
        "build": "node scripts/build.js",
        "build:claude": "node scripts/build.js claude",
        "build:cursor": "node scripts/build.js cursor",
        "build:antigravity": "node scripts/build.js antigravity",
        "build:codex": "node scripts/build.js codex",
        "build:opencode": "node scripts/build.js opencode",
        "build:pi": "node scripts/build.js pi",
        "prepublishOnly": "npm run build"
    },
    "author": "Baller Software",
    "repository": {
        "url": "https://github.com/gballer77/gspec"
    },
    "license": "MIT",
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^11.1.0"
    }
}
