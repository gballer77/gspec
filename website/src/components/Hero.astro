---
import CopyButton from './CopyButton.astro';
---

<section class="py-16 sm:py-24 lg:py-32">
  <div class="max-w-[1152px] mx-auto px-4 lg:px-8 text-center">
    <h1 class="text-[2.5rem] sm:text-[3rem] lg:text-[3.5rem] font-bold leading-[1.1] tracking-tight text-[var(--text-primary)] mb-6">
      Living specs for AI-assisted development.
    </h1>
    <p class="text-lg sm:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-6 leading-relaxed">
      Give your AI coding tools the product context they need — structured specifications that stay in sync with your code.
    </p>
    <p class="text-sm sm:text-base text-[var(--text-secondary)] max-w-2xl mx-auto mb-10 leading-relaxed">
      Now with <strong class="text-[var(--text-primary)]">renderable HTML design systems</strong> and a <strong class="text-[var(--text-primary)]">design folder</strong> for mockups from tools like Figma, v0, and Framer AI — so your AI agent can see your design, not just read about it.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <div class="inline-flex items-center gap-3 bg-[var(--bg-surface-raised)] border border-[var(--border-default)] rounded-lg px-5 py-3 font-mono text-sm sm:text-base text-[var(--text-primary)]">
        <span class="text-primary-400 select-none">$</span>
        <span>npx gspec</span>
        <CopyButton text="npx gspec" />
      </div>
      <a
        href={`${import.meta.env.BASE_URL}getting-started/`}
        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-medium text-[var(--text-body)] border border-[var(--border-default)] hover:border-neutral-600 hover:bg-[var(--bg-surface-raised)] transition-all duration-200"
      >
        Get Started
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
