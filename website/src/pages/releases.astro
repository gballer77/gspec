  {
    version: '1.0.3',
    date: 'February 13, 2026',
    title: 'Package metadata',
    summary: 'Added repository URL and branding to the npm package.',
    changes: [
      {
        type: 'changed',
        description: 'Added repository URL to <code>package.json</code> for npm listing.',
      },
    ],
  },
  {
    version: '1.0.2',
    date: 'February 13, 2026',
    title: 'Initial release',
    summary: 'First published version of gspec with the core specification workflow and multi-platform support.',
    changes: [
      {
        type: 'added',
        description: 'Core specification commands: <code>profile</code>, <code>style</code>, <code>stack</code>, <code>practices</code>, <code>feature</code>, <code>epic</code>, <code>implement</code>, <code>dor</code>, <code>record</code>.',
      },
      {
        type: 'added',
        description: 'Build pipeline and <code>npx gspec</code> installer for Claude Code, Cursor, and Antigravity.',
      },
      {
        type: 'added',
        description: 'Incremental implementation tracking with capability checkboxes in feature PRDs.',
      },
    ],
  },
];

const typeColors: Record<string, { bg: string; text: string; label: string }> = {
  added: { bg: 'bg-emerald-500/10', text: 'text-emerald-400', label: 'Added' },
  changed: { bg: 'bg-amber-500/10', text: 'text-amber-400', label: 'Changed' },
  removed: { bg: 'bg-red-500/10', text: 'text-red-400', label: 'Removed' },
  fixed: { bg: 'bg-blue-500/10', text: 'text-blue-400', label: 'Fixed' },
};
---

<BaseLayout title="Releases — gspec" description="Release notes and changelog for gspec — what's new in each version.">
  <Navbar slot="navbar" />

  <div class="max-w-[768px] mx-auto px-4 lg:px-8 py-12">
    <h1 class="text-[1.953rem] sm:text-[2.441rem] font-bold tracking-tight text-[var(--text-primary)] mb-2">
      Releases
    </h1>
    <p class="text-lg text-[var(--text-secondary)] mb-16">
      What's new in each version of gspec.
    </p>

    <div class="space-y-16">
      {releases.map((release, i) => (
        <article id={`v${release.version}`} class="relative scroll-mt-20">
          {/* Version badge and date */}
          <div class="flex items-center gap-3 mb-3">
            <a
              href={`#v${release.version}`}
              class="group inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-mono font-semibold bg-[var(--bg-primary-subtle)] text-[var(--text-accent)] border border-[var(--border-primary-subtle)] no-underline hover:bg-[var(--bg-primary)] hover:text-[var(--text-on-primary)] transition-colors"
              aria-label={`Permalink to v${release.version}`}
            >
              v{release.version}
              <span class="opacity-0 group-hover:opacity-70 transition-opacity" aria-hidden="true">#</span>
            </a>
            <time class="text-sm text-[var(--text-muted)]">{release.date}</time>
            {i === 0 && (
              <span class="text-[10px] font-medium uppercase tracking-wider text-[var(--badge-accent-text)] bg-[var(--badge-accent-bg)] px-1.5 py-0.5 rounded">
                Latest
              </span>
            )}
          </div>

          {/* Title and summary */}
          <h2 class="text-[1.25rem] sm:text-[1.563rem] font-semibold text-[var(--text-primary)] mb-2 tracking-tight">
            {release.title}
          </h2>
          <p class="text-[var(--text-body)] leading-relaxed mb-6 [&_code]:text-[var(--code-text)] [&_code]:bg-[var(--bg-surface-raised)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-xs [&_code]:font-mono" set:html={release.summary} />


          {/* Changes list */}
          <div class="space-y-3">
            {release.changes.map((change) => {
              const colors = typeColors[change.type] || typeColors.added;
              return (
                <div class="flex gap-3">
                  <span class:list={[
                    'inline-flex items-center justify-center shrink-0 px-2 py-0.5 rounded text-xs font-medium mt-0.5',
                    colors.bg, colors.text,
                  ]}>
                    {colors.label}
                  </span>
                  <p class="text-sm text-[var(--text-body)] leading-relaxed [&_code]:text-[var(--code-text)] [&_code]:bg-[var(--bg-surface-raised)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-xs [&_code]:font-mono" set:html={change.description} />
                </div>
              );
            })}
          </div>

          {/* Migration note */}
          {release.migration && (
            <div class="mt-6 p-4 rounded-lg border border-[var(--border-default)] bg-[var(--bg-surface)]">
              <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Migration</h4>
              <p class="text-sm text-[var(--text-secondary)] leading-relaxed [&_code]:text-[var(--code-text)] [&_code]:bg-[var(--bg-surface-raised)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-xs [&_code]:font-mono" set:html={release.migration} />
            </div>
          )}

          {/* Separator */}
          {i < releases.length - 1 && (
            <hr class="mt-16 border-[var(--border-subtle)]" />
          )}
        </article>
      ))}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
