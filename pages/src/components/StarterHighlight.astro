---
const base = import.meta.env.BASE_URL;

const categories = [
  {
    title: 'Stacks',
    count: 3,
    examples: ['Next.js + Supabase + Vercel', 'Astro + Tailwind + GitHub Pages'],
  },
  {
    title: 'Practices',
    count: 1,
    examples: ['TDD Pipeline-First'],
  },
  {
    title: 'Styles',
    count: 2,
    examples: ['Clean Professional', 'Dark Minimal Developer'],
  },
  {
    title: 'Features',
    count: 8,
    examples: ['Home Page', 'Contact Form', 'Responsive Navbar', 'Theme Switcher'],
  },
];
---

<section class="py-16 lg:py-24">
  <div class="max-w-[1152px] mx-auto px-4 lg:px-8">
    <h2 class="text-2xl sm:text-[1.953rem] font-semibold text-[var(--text-primary)] text-center mb-4 tracking-tight">
      Start with templates, not a blank page
    </h2>
    <p class="text-[var(--text-secondary)] text-center mb-12 max-w-2xl mx-auto">
      The installer offers pre-built starter templates for common stacks, practices, styles, and features. Pick what fits, then customize.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {categories.map((cat) => (
        <div class="rounded-lg border border-[var(--border-default)] bg-[var(--bg-surface)] p-5 hover:border-neutral-600 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-3">
            <h3 class="text-sm font-semibold text-[var(--text-primary)]">{cat.title}</h3>
            <span class="text-xs font-mono text-[var(--text-muted)]">{cat.count}</span>
          </div>
          <ul class="space-y-1.5">
            {cat.examples.map((ex) => (
              <li class="text-sm text-[var(--text-secondary)] leading-snug">{ex}</li>
            ))}
            {cat.count > cat.examples.length && (
              <li class="text-xs text-[var(--text-muted)]">+ {cat.count - cat.examples.length} more</li>
            )}
          </ul>
        </div>
      ))}
    </div>

    <p class="text-sm text-[var(--text-muted)] text-center mt-8">
      <a href={`${base}starters/`} class="text-primary-400 hover:text-primary-300 underline decoration-primary-400/30 hover:decoration-primary-400/60 transition-colors duration-200">Browse all starters</a>
    </p>
  </div>
</section>
