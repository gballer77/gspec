---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-[var(--border-subtle)] py-12">
  <div class="max-w-[1152px] mx-auto px-4 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <a href={base} class="text-[var(--text-primary)] font-semibold">gspec</a>
        <nav class="flex items-center gap-4 text-sm">
          <a href={`${base}getting-started/`} class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Getting Started</a>
          <a href={`${base}docs/`} class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Docs</a>
          <a href="https://github.com/glBall/gspec" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200" target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
      </div>
      <p class="text-sm text-[var(--text-muted)]">
        Open source under MIT License
      </p>
    </div>
  </div>
</footer>
