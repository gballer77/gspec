---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'gspec — Living specs for AI-assisted development',
  description = 'Give your AI coding tools the product context they need — structured specifications that stay in sync with your code.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/inter-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/jetbrains-mono-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', stored || preferred);
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="navbar" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
