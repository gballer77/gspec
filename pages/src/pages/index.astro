---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import WorkflowOverview from '../components/WorkflowOverview.astro';
import CommandsOverview from '../components/CommandsOverview.astro';
import PlatformSupport from '../components/PlatformSupport.astro';
import StarterHighlight from '../components/StarterHighlight.astro';
import BottomCta from '../components/BottomCta.astro';
---

<BaseLayout>
  <Navbar slot="navbar" />
  <Hero />
  <ProblemStatement />
  <WorkflowOverview />
  <CommandsOverview />
  <StarterHighlight />
  <PlatformSupport />
  <BottomCta />
  <Footer slot="footer" />
</BaseLayout>
